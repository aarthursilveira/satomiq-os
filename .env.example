# === DATABASE ===
DB_NAME=satomiq_os
DB_USER=satomiq
DB_PASSWORD=changeme_in_production
DATABASE_URL=postgresql://satomiq:changeme_in_production@localhost:5432/satomiq_os

# === BACKEND ===
NODE_ENV=development
PORT=3001
JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production_min_32_chars
